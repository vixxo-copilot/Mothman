# .env.example — credential template for assistants-template
# Copy this file to `.env` and fill in values for the MCPs you use.
# `.env` is gitignored (see `.gitignore`). `.env.example` is tracked (allowlist: `!.env.example`).
# NEVER commit `.env.example` with real values — every RHS below is intentionally blank or commented.
# Sections are ordered: ACTIVE MCPs first (mcp.json order), then PLACEHOLDER MCPs (mcp.placeholders.md order).

# === ACTIVE MCPs (wired in .cursor/mcp.json — see .cursor/mcp.README.md) ===

# --- linear ---
# status: active-no-env
# Purpose: Vixxo work task and project management (issues, projects, cycles).
# Transport: remote URL (HTTP)
# Auth: OAuth 2.1 interactive via Cursor's MCP UI on first connect.
# Wiring link: https://linear.app/docs/mcp

# --- github ---
# status: active
# Purpose: Source control, code review, repository documentation, PR automation.
# Transport: local stdio (bin/run-github-mcp.sh + bin/github-mcp-server)
# Auth: gh auth login (default) or export GITHUB_PERSONAL_ACCESS_TOKEN
# Wiring link: https://github.com/github/github-mcp-server
GITHUB_PERSONAL_ACCESS_TOKEN=

# --- microsoft-365 ---
# status: active
# Purpose: Outlook mail/calendar, OneDrive files, Teams chat, Microsoft Graph API coverage.
# Transport: local stdio (npx)
# Auth: Device-code flow on first run; token cached in OS keychain.
# Wiring link: https://github.com/softeria/ms-365-mcp-server
# MS365_MCP_CLIENT_ID=
# MS365_MCP_TENANT_ID=

# --- salesforce ---
# status: active-no-env
# Purpose: CRM, pipeline, accounts, contacts, Apex execution, SOQL queries.
# Transport: local stdio (npx)
# Auth: Salesforce CLI (`sf`) session at `~/.sf/`; run `sf org login web` once out of band.
# Wiring link: https://github.com/salesforcecli/mcp

# --- gong ---
# status: active
# Purpose: Call recordings, transcripts, deal intelligence.
# Transport: local stdio (npx)
# Auth: Shell env inherited (variables exported in shell rc before launching Cursor).
# Wiring link: https://github.com/kenazk/gong-mcp
GONG_ACCESS_KEY=
GONG_ACCESS_KEY_SECRET=

# --- smartsheet ---
# status: active
# Purpose: Smartsheet sheets, rows, reports, and workspace data.
# Transport: local stdio (npx mcp-remote → https://mcp.smartsheet.com)
# Auth: Personal access token via SMARTSHEET_API_TOKEN (include Bearer prefix).
# Wiring link: https://developers.smartsheet.com/ai-mcp/smartsheet/install-the-smartsheet-mcp-server
SMARTSHEET_API_TOKEN=

# --- freshservice (extended active MCP in .cursor/mcp.json) ---
# Required for Freshservice API tools (MCP connects without it; tools fail until set).
# Setup: bin/setup-freshservice-mcp.sh
# Or save key to ~/.vixxo/freshservice_api_key
FRESHSERVICE_API_KEY=
FRESHSERVICE_DOMAIN=vixxo.freshservice.com

# --- polyai (skill-based tool — NOT an MCP; separate from .cursor/mcp.json) ---
# Main skill: .agents/skills/polyai/  |  Studio MCP wiring: polyai-vixxo-bridge
# Conversations API v3 — provision key via PolyAI representative.
# Account/project IDs: first two path segments of your Agent Studio URL.
# Docs: .agents/skills/polyai/reference/api.md
POLYAI_API_KEY=
POLYAI_REGION=us
POLYAI_ACCOUNT_ID=vixxo-us
POLYAI_PROJECT_ID=vixxo-outbound-usp
# Optional — additional USP project IDs (comma-separated)
# POLYAI_EXTRA_PROJECT_IDS=vixxo-inbound-usp
# Optional — separate workspace key for Agents API (build/deploy)
# POLYAI_AGENTS_API_KEY=

