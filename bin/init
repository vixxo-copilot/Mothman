#!/usr/bin/env node
// assistants-template — setup wizard (Epic 5).
// Story 5.2: prompt flow + deterministic file generation.
// Story 5.3: post-wizard skills install + active MCP verification.

'use strict';

const fs = require('node:fs');
const fsp = require('node:fs/promises');
const os = require('node:os');
const path = require('node:path');
const crypto = require('node:crypto');
const { spawnSync } = require('node:child_process');

const ROOT = path.join(__dirname, '..');
const PKG_PATH = path.join(ROOT, 'package.json');
const NODE_MODULES_PROMPTS = path.join(ROOT, 'node_modules', 'prompts', 'package.json');
const MCPS_DOC_PATH = path.join(ROOT, 'docs', 'mcps.md');
const ENV_EXAMPLE_PATH = path.join(ROOT, '.env.example');
const MCP_CONFIG_PATH = path.join(ROOT, '.cursor', 'mcp.json');

const IDENTITY_RELATIVE_PATH = path.join('memory', 'me', 'identity.md');
const WORK_PERSONA_RELATIVE_PATH = path.join('agents', 'personas', 'work.md');
const ENV_RELATIVE_PATH = '.env';

const FIXTURE_ENV_VAR = 'BMAD_STORY_5_2_FIXTURE_PATH';
const STORY_5_3_FIXTURE_ENV_VAR = 'BMAD_STORY_5_3_FIXTURE_PATH';
const BASIC_EMAIL_REGEX = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
const SKILLS_INSTALL_ARGS = ['skills', 'add', 'vixxo-copilot/agent-skills'];
const SKILLS_INSTALL_COMMAND = 'npx ' + SKILLS_INSTALL_ARGS.join(' ');
const PROBE_TIMEOUT_MS = 5000;

const MCP_REMEDIATION_MAP = Object.freeze({
  linear: 'Reconnect in Cursor MCP UI and review https://linear.app/docs/mcp',
  github:
    'Run gh auth login if needed, ensure bin/github-mcp-server exists (see .cursor/mcp.README.md § GitHub), then restart the GitHub MCP in Cursor',
  'microsoft-365': 'Rerun Microsoft 365 device-code auth and review https://github.com/softeria/ms-365-mcp-server',
  salesforce: 'Run sf org login web and ensure @salesforce/cli is installed',
  gong: 'Export GONG_ACCESS_KEY and GONG_ACCESS_KEY_SECRET; review https://github.com/kenazk/gong-mcp'
});

const writeQueueByPath = new Map();

function loadPackage() {
  return JSON.parse(fs.readFileSync(PKG_PATH, 'utf8'));
}

function printHelp(pkg) {
  console.log('assistants-template — setup wizard');
  console.log('');
  console.log('Usage: ./bin/init [--help | -h] [--version | -v]');
  console.log('');
  console.log('Story 5.1: bootstrap entry point + dependency setup.');
  console.log('Story 5.2: prompts + deterministic file generation.');
  console.log('Story 5.3: post-wizard skills install + MCP verification.');
  console.log('');
  console.log('Version: ' + pkg.version);
}

function printVersion(pkg) {
  console.log('assistants-template init ' + pkg.version);
}

function ensureDependencies() {
  if (fs.existsSync(NODE_MODULES_PROMPTS)) return;
  console.log('Installing local dependencies (first-run only)...');
  const result = spawnSync('npm', ['install'], { cwd: ROOT, stdio: 'inherit' });
  if (result.error) {
    const exitCode = result.error.code === 'ENOENT' ? 127 : 1;
    const reason = result.error.code || result.error.message || 'unknown';
    console.error('[bin/init] npm install failed; exit ' + String(exitCode) + '. Cause: ' + reason + ". Please run 'npm install' manually and retry.");
    process.exit(exitCode);
  }

  if (result.signal) {
    const signalNumber = os.constants.signals[result.signal];
    const exitCode = typeof signalNumber === 'number' ? 128 + signalNumber : 1;
    console.error('[bin/init] npm install failed; signal ' + result.signal + '; exit ' + String(exitCode) + ". Please run 'npm install' manually and retry.");
    process.exit(exitCode);
  }

  if (typeof result.status === 'number' && result.status !== 0) {
    console.error('[bin/init] npm install failed; exit ' + String(result.status) + ". Please run 'npm install' manually and retry.");
    process.exit(result.status);
  }
  console.log('Dependencies installed.');
}

function normalizeWhitespace(input) {
  return String(input || '').trim().replace(/\s+/g, ' ');
}

function normalizeEmail(input) {
  return String(input || '').trim().toLowerCase();
}

function parseCanonicalMcpKeysFromDocs(docContent) {
  const keys = [];
  const lines = docContent.split('\n');
  for (const line of lines) {
    const match = line.match(/^\|\s*([a-z0-9-]+)\s*\|\s*(active|active-no-env|placeholder)\s*\|/i);
    if (match) {
      keys.push(match[1]);
    }
  }
  return keys;
}

function loadCanonicalMcpKeys() {
  const docContent = fs.readFileSync(MCPS_DOC_PATH, 'utf8');
  const keys = parseCanonicalMcpKeysFromDocs(docContent);
  if (keys.length === 0) {
    throw new Error('unable to parse canonical MCP keys from docs/mcps.md');
  }
  return keys;
}

function deriveDepartmentFromRole(role) {
  const roleLower = role.toLowerCase();
  const rules = [
    { department: 'Engineering', tokens: ['engineer', 'developer', 'architect', 'qa', 'sre', 'devops'] },
    { department: 'Product', tokens: ['product', 'pm'] },
    { department: 'Design', tokens: ['design', 'ux', 'ui'] },
    { department: 'Sales', tokens: ['sales', 'account executive', 'business development'] },
    { department: 'Marketing', tokens: ['marketing', 'growth'] },
    { department: 'Operations', tokens: ['operations', 'ops'] },
    { department: 'Finance', tokens: ['finance', 'accounting'] },
    { department: 'People', tokens: ['hr', 'people', 'talent'] }
  ];

  for (const rule of rules) {
    if (rule.tokens.some((token) => roleLower.includes(token))) {
      return rule.department;
    }
  }
  return 'General';
}

function deriveManagerPlaceholder(department) {
  return department + ' Manager (TBD)';
}

function normalizeSelectedMcps(selectedMcps, canonicalMcpKeys) {
  const selectedSet = new Set(Array.isArray(selectedMcps) ? selectedMcps : []);
  return canonicalMcpKeys.filter((key) => selectedSet.has(key));
}

function normalizeWizardAnswers(rawAnswers, canonicalMcpKeys) {
  const employeeName = normalizeWhitespace(rawAnswers.employeeName);
  const employeeRole = normalizeWhitespace(rawAnswers.employeeRole);
  const employeeEmail = normalizeEmail(rawAnswers.employeeEmail);
  const department = deriveDepartmentFromRole(employeeRole);
  const manager = deriveManagerPlaceholder(department);
  const optionalMcps = normalizeSelectedMcps(rawAnswers.optionalMcps, canonicalMcpKeys);

  return {
    employeeName,
    employeeRole,
    employeeEmail,
    department,
    manager,
    optionalMcps
  };
}

function normalizeOutputText(content) {
  const lf = String(content).replace(/\r\n/g, '\n').replace(/\r/g, '\n');
  return lf.endsWith('\n') ? lf : lf + '\n';
}

function yamlDoubleQuoted(value) {
  return String(value)
    .replace(/\\/g, '\\\\')
    .replace(/"/g, '\\"')
    .replace(/\n/g, '\\n');
}

function assertPathInsideRepo(targetPath) {
  const resolved = path.resolve(ROOT, targetPath);
  const rootWithSep = ROOT.endsWith(path.sep) ? ROOT : ROOT + path.sep;
  if (resolved !== ROOT && !resolved.startsWith(rootWithSep)) {
    throw new Error('path escapes repository root: ' + targetPath);
  }
  return resolved;
}

async function withSerializedWrite(targetPath, operation) {
  const prior = writeQueueByPath.get(targetPath) || Promise.resolve();
  const next = prior.then(operation, operation);
  const wrapped = next.finally(() => {
    if (writeQueueByPath.get(targetPath) === wrapped) {
      writeQueueByPath.delete(targetPath);
    }
  });
  writeQueueByPath.set(targetPath, wrapped);
  return next;
}

async function writeAtomic(targetPath, content) {
  const resolvedTarget = assertPathInsideRepo(targetPath);
  const directory = path.dirname(resolvedTarget);
  const tempFile = path.join(
    directory,
    '.tmp-' + path.basename(resolvedTarget) + '.' + process.pid + '.' + Date.now() + '.' + crypto.randomBytes(4).toString('hex')
  );
  const normalizedContent = normalizeOutputText(content);

  return withSerializedWrite(resolvedTarget, async () => {
    try {
      await fsp.writeFile(tempFile, normalizedContent, 'utf8');
      await fsp.rename(tempFile, resolvedTarget);
    } catch (error) {
      try {
        await fsp.unlink(tempFile);
      } catch {
        // Best-effort cleanup only; keep original failure context.
      }
      throw error;
    }
  });
}

function renderOptionalMcpsSection(optionalMcps) {
  if (optionalMcps.length === 0) {
    return 'none selected';
  }
  return optionalMcps.map((mcpKey) => '- ' + mcpKey).join('\n');
}

