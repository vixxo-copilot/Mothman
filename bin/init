async function materializeEnvFile(overwriteEnv) {
  const envPath = assertPathInsideRepo(ENV_RELATIVE_PATH);
  const envExamplePath = assertPathInsideRepo(ENV_EXAMPLE_PATH);
  const envExampleContents = await fsp.readFile(envExamplePath, 'utf8');

  let exists = false;
  try {
    await fsp.access(envPath);
    exists = true;
  } catch (error) {
    exists = false;
  }

  if (exists && !overwriteEnv) {
    return { changed: false, action: 'skipped', path: ENV_RELATIVE_PATH };
  }

  await writeAtomic(envPath, envExampleContents);
  return { changed: true, action: exists ? 'overwritten' : 'created', path: ENV_RELATIVE_PATH };
}

function mapFixtureResponse(item, index) {
  if (item && typeof item === 'object' && !Array.isArray(item)) {
    if (item.type === 'error') {
      const message = typeof item.message === 'string' && item.message.trim() !== '' ? item.message : 'fixture-cancelled';
      const error = new Error(message);
      error.code = 'WIZARD_CANCELLED';
      return error;
    }
  }
  return item;
}

function loadFixtureResponsesIfPresent(env) {
  const fixturePathRaw = env[FIXTURE_ENV_VAR];
  if (!fixturePathRaw) {
    return null;
  }

  const fixturePath = assertPathInsideRepo(fixturePathRaw);
  const fixtureText = fs.readFileSync(fixturePath, 'utf8');
  let parsedFixture;
  try {
    parsedFixture = JSON.parse(fixtureText);
  } catch (error) {
    throw new Error('invalid fixture JSON at ' + fixturePath + ': ' + error.message);
  }

  if (!parsedFixture || typeof parsedFixture !== 'object' || Array.isArray(parsedFixture)) {
    throw new Error('invalid fixture payload at ' + fixturePath + ': expected object');
  }
  if (!Array.isArray(parsedFixture.responses)) {
    throw new Error('invalid fixture payload at ' + fixturePath + ': missing responses array');
  }

  return parsedFixture.responses.map((item, index) => mapFixtureResponse(item, index));
}

function validateFixtureResponses(responses, shouldAskEnvOverwrite) {
  const isCancelError = (value) => value instanceof Error && value.code === 'WIZARD_CANCELLED';
  const requireIndex = (index) => {
    if (!Array.isArray(responses) || responses.length <= index) {
      throw new Error('invalid fixture payload: responses[' + String(index) + '] required');
    }
    return responses[index];
  };
  if (!Array.isArray(responses)) {
    throw new Error('invalid fixture payload: responses must be an array');
  }

  const response0 = requireIndex(0);

  if (isCancelError(response0)) return;
  if (typeof response0 !== 'string') throw new Error('invalid fixture payload: responses[0] must be string');

  const response1 = requireIndex(1);
  if (isCancelError(response1)) return;
  if (typeof response1 !== 'string') throw new Error('invalid fixture payload: responses[1] must be string');

  const response2 = requireIndex(2);
  if (isCancelError(response2)) return;
  if (typeof response2 !== 'string') throw new Error('invalid fixture payload: responses[2] must be string');

  const response3 = requireIndex(3);
  if (isCancelError(response3)) return;
  if (!Array.isArray(response3)) throw new Error('invalid fixture payload: responses[3] must be array');

  if (shouldAskEnvOverwrite) {
    const response4 = requireIndex(4);
    if (typeof response4 !== 'boolean' && !isCancelError(response4)) {
      throw new Error('invalid fixture payload: responses[4] must be boolean for overwrite prompt');
    }
  }
}

function mcpRemediationFor(serverKey) {
  return MCP_REMEDIATION_MAP[serverKey] || 'See docs/mcps.md and .cursor/mcp.README.md for setup guidance.';
}

function normalizeProbeStatus(status) {
  return status === 'PASS' ? 'PASS' : 'FAIL';
}

function normalizeProbeReason(reason, fallback) {
  if (typeof reason === 'string' && reason.trim() !== '') {
    return reason.trim();
  }
  return fallback;
}

function makeProbeResult(serverKey, status, reason, remediation) {
  return {
    server_key: serverKey,
    status: normalizeProbeStatus(status),
    reason: reason,
    remediation: remediation
  };
}

function validateStory53FixturePayload(payload) {
  if (!payload || typeof payload !== 'object' || Array.isArray(payload)) {
    throw new Error('invalid Story 5.3 fixture payload: expected object');
  }
  if (!payload.skillsInstall || typeof payload.skillsInstall !== 'object' || Array.isArray(payload.skillsInstall)) {
    throw new Error('invalid Story 5.3 fixture payload: skillsInstall object is required');
  }
  if (!payload.mcpResults || typeof payload.mcpResults !== 'object' || Array.isArray(payload.mcpResults)) {
    throw new Error('invalid Story 5.3 fixture payload: mcpResults object is required');
  }

  const validateResultObject = (result, pathLabel) => {
    if (!result || typeof result !== 'object' || Array.isArray(result)) {
      throw new Error('invalid Story 5.3 fixture payload: ' + pathLabel + ' must be object');
    }
    if (result.status !== 'PASS' && result.status !== 'FAIL') {
      throw new Error('invalid Story 5.3 fixture payload: ' + pathLabel + '.status must be PASS or FAIL');
    }
    if (Object.prototype.hasOwnProperty.call(result, 'reason')) {
      if (typeof result.reason !== 'string' || result.reason.trim() === '') {
        throw new Error('invalid Story 5.3 fixture payload: ' + pathLabel + '.reason must be non-empty string when provided');
      }
    }
  };

  validateResultObject(payload.skillsInstall, 'skillsInstall');

  const mcpEntries = Object.entries(payload.mcpResults);
  if (mcpEntries.length === 0) {
    throw new Error('invalid Story 5.3 fixture payload: mcpResults must include at least one server entry');
  }
  for (const [serverKey, result] of mcpEntries) {
    if (typeof serverKey !== 'string' || serverKey.trim() === '') {
      throw new Error('invalid Story 5.3 fixture payload: mcpResults contains empty server key');
    }
    validateResultObject(result, 'mcpResults.' + serverKey);
  }
}

function loadStory53FixtureIfPresent(env) {
  const fixturePathRaw = env[STORY_5_3_FIXTURE_ENV_VAR];
  if (!fixturePathRaw) {
    return null;
  }

  const fixturePath = assertPathInsideRepo(fixturePathRaw);
  const fixtureText = fs.readFileSync(fixturePath, 'utf8');
  let parsedFixture;
  try {
    parsedFixture = JSON.parse(fixtureText);
  } catch (error) {
    throw new Error('invalid Story 5.3 fixture JSON at ' + fixturePath + ': ' + error.message);
  }

  validateStory53FixturePayload(parsedFixture);
  return parsedFixture;
}

function loadActiveMcpConfig(mcpConfigPath = MCP_CONFIG_PATH) {
  const raw = fs.readFileSync(mcpConfigPath, 'utf8');
  let parsed;
  try {
    parsed = JSON.parse(raw);
  } catch (error) {
    throw new Error('unable to parse .cursor/mcp.json: ' + error.message + '. Check .cursor/mcp.json for valid JSON.');
  }

  if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) {
    throw new Error('invalid .cursor/mcp.json: root must be an object. Check .cursor/mcp.json.');
  }
  if (!parsed.mcpServers || typeof parsed.mcpServers !== 'object' || Array.isArray(parsed.mcpServers)) {
    throw new Error('invalid .cursor/mcp.json: mcpServers object is required. Check .cursor/mcp.json.');
  }

  return {
    mcpServers: parsed.mcpServers,
    activeKeys: Object.keys(parsed.mcpServers)
  };
}

function loadActiveMcpServerKeys(mcpConfigPath = MCP_CONFIG_PATH) {
  return loadActiveMcpConfig(mcpConfigPath).activeKeys;
}

function checkCommandAvailability(command, args, spawnSyncImpl) {
  const result = spawnSyncImpl(command, args, {
    cwd: ROOT,
    stdio: 'pipe',
    encoding: 'utf8',
    timeout: PROBE_TIMEOUT_MS
  });
  if (result.error) {
    const reason = result.error.code || result.error.message || 'unknown error';
    return { ok: false, reason: 'command ' + command + ' unavailable: ' + reason };
  }
  if (result.signal) {
    return { ok: false, reason: 'command ' + command + ' terminated by signal ' + result.signal };
  }
  if (typeof result.status === 'number' && result.status !== 0) {
    return { ok: false, reason: 'command ' + command + ' exited with status ' + String(result.status) };
  }
  return { ok: true, reason: command + ' check passed' };
}

function validateServerConfigObject(serverKey, serverConfig) {
  if (!serverConfig || typeof serverConfig !== 'object' || Array.isArray(serverConfig)) {
    return serverKey + ' MCP config missing object entry';
  }
  return null;
}

function probeLinear(serverConfig) {
  const configError = validateServerConfigObject('linear', serverConfig);
  if (configError) {
    return { status: 'FAIL', reason: configError };
  }
  if (typeof serverConfig.url !== 'string' || serverConfig.url.trim() === '') {
    return { status: 'FAIL', reason: 'linear MCP config missing url' };
  }
  return { status: 'PASS', reason: 'linear MCP URL is configured' };
}

function probeGithub(serverConfig, env, spawnSyncImpl) {
  const configError = validateServerConfigObject('github', serverConfig);
  if (configError) {
    return { status: 'FAIL', reason: configError };
  }
  if (!env.GITHUB_PERSONAL_ACCESS_TOKEN || String(env.GITHUB_PERSONAL_ACCESS_TOKEN).trim() === '') {
    return { status: 'FAIL', reason: 'required env var GITHUB_PERSONAL_ACCESS_TOKEN is not set' };
  }
  const dockerCheck = checkCommandAvailability('docker', ['--version'], spawnSyncImpl);
  if (!dockerCheck.ok) {
    return { status: 'FAIL', reason: dockerCheck.reason };
  }
  return { status: 'PASS', reason: 'github MCP config present, docker is available, and required GitHub token env var is set' };
}

function probeMicrosoft365(serverConfig, spawnSyncImpl) {
  const configError = validateServerConfigObject('microsoft-365', serverConfig);
  if (configError) {
    return { status: 'FAIL', reason: configError };
  }
  const npxCheck = checkCommandAvailability('npx', ['--version'], spawnSyncImpl);
  if (!npxCheck.ok) {
    return { status: 'FAIL', reason: npxCheck.reason };
  }
  return { status: 'PASS', reason: 'microsoft-365 MCP config present and npx is available for server startup' };
}

function probeSalesforce(serverConfig, spawnSyncImpl) {
  const configError = validateServerConfigObject('salesforce', serverConfig);
  if (configError) {
    return { status: 'FAIL', reason: configError };
  }
  const npxCheck = checkCommandAvailability('npx', ['--version'], spawnSyncImpl);
  if (!npxCheck.ok) {
    return { status: 'FAIL', reason: npxCheck.reason };
  }
  const sfCheck = checkCommandAvailability('sf', ['--version'], spawnSyncImpl);
  if (!sfCheck.ok) {
    return { status: 'FAIL', reason: sfCheck.reason };
  }
  return { status: 'PASS', reason: 'salesforce MCP config present and required CLIs (npx, sf) are available' };
}

function probeGong(serverConfig, env, spawnSyncImpl) {
  const configError = validateServerConfigObject('gong', serverConfig);
  if (configError) {
    return { status: 'FAIL', reason: configError };
  }
  const missing = [];
  if (!env.GONG_ACCESS_KEY || String(env.GONG_ACCESS_KEY).trim() === '') missing.push('GONG_ACCESS_KEY');
  if (!env.GONG_ACCESS_KEY_SECRET || String(env.GONG_ACCESS_KEY_SECRET).trim() === '') missing.push('GONG_ACCESS_KEY_SECRET');
  if (missing.length > 0) {
    return { status: 'FAIL', reason: 'required env var(s) missing: ' + missing.join(', ') };
  }

  const npxCheck = checkCommandAvailability('npx', ['--version'], spawnSyncImpl);
  if (!npxCheck.ok) {
    return { status: 'FAIL', reason: npxCheck.reason };
  }
  return { status: 'PASS', reason: 'gong MCP config present, npx is available, and required Gong env vars are set' };
}

function probeDefaultServer(serverKey, serverConfig, spawnSyncImpl) {
  if (!serverConfig || typeof serverConfig !== 'object' || Array.isArray(serverConfig)) {
    return { status: 'FAIL', reason: serverKey + ' MCP config missing object entry' };
  }
  if (typeof serverConfig.command === 'string' && serverConfig.command.trim() !== '') {
    const commandCheck = checkCommandAvailability(serverConfig.command, ['--version'], spawnSyncImpl);
    if (!commandCheck.ok) {
      return { status: 'FAIL', reason: commandCheck.reason };
    }
    return { status: 'PASS', reason: serverKey + ' command prerequisite is available' };
  }
  if (typeof serverConfig.url === 'string' && serverConfig.url.trim() !== '') {
    return { status: 'PASS', reason: serverKey + ' remote URL is configured' };
  }
  return { status: 'FAIL', reason: serverKey + ' MCP config has no command or url to verify' };
}

function validateStory53FixtureAgainstActiveKeys(fixture, activeKeys) {
  if (!fixture) return;
  const fixtureKeys = Object.keys(fixture.mcpResults);
  const activeKeySet = new Set(activeKeys);
  for (const fixtureKey of fixtureKeys) {
    if (!activeKeySet.has(fixtureKey)) {
      throw new Error('invalid Story 5.3 fixture payload: mcpResults includes non-active key ' + fixtureKey);
    }
  }
  for (const activeKey of activeKeys) {
    if (!Object.prototype.hasOwnProperty.call(fixture.mcpResults, activeKey)) {
      throw new Error('invalid Story 5.3 fixture payload: mcpResults missing active key ' + activeKey);
    }
  }
}

function runSkillsInstall(env, options = {}) {
  const fixture = options.fixture || null;
  if (fixture) {
    const fixtureReason = normalizeProbeReason(fixture.skillsInstall.reason, 'fixture-simulated skills install result');
    return {
      status: fixture.skillsInstall.status,
      reason: fixtureReason,
      remediation: 'Re-run command: ' + SKILLS_INSTALL_COMMAND
    };
  }

  const spawnSyncImpl = options.spawnSyncImpl || spawnSync;
  const result = spawnSyncImpl('npx', SKILLS_INSTALL_ARGS, {
    cwd: ROOT,
    stdio: 'inherit',
    env: env
  });

  if (result.error) {
    const reason = result.error.code || result.error.message || 'unknown error';
    return {
      status: 'FAIL',
      reason: 'skills install spawn error: ' + reason,
      remediation: 'Re-run command: ' + SKILLS_INSTALL_COMMAND
    };
  }
  if (result.signal) {
    return {
      status: 'FAIL',
      reason: 'skills install terminated by signal ' + result.signal,
      remediation: 'Re-run command: ' + SKILLS_INSTALL_COMMAND
    };
  }
  if (typeof result.status === 'number' && result.status !== 0) {
    return {
      status: 'FAIL',
      reason: 'skills install exited with status ' + String(result.status),
      remediation: 'Re-run command: ' + SKILLS_INSTALL_COMMAND
    };
  }

  return {
    status: 'PASS',
    reason: 'skills install command completed successfully',
    remediation: 'none'
  };
}

function verifyActiveMcps(env, options = {}) {
  const spawnSyncImpl = options.spawnSyncImpl || spawnSync;
  const fixture = options.fixture || null;

  let activeKeys = options.activeKeys || null;
  let mcpServers = options.mcpServers || {};

  if (!activeKeys) {
    try {
      const loaded = loadActiveMcpConfig(options.mcpConfigPath || MCP_CONFIG_PATH);
      activeKeys = loaded.activeKeys;
      mcpServers = loaded.mcpServers;
    } catch (error) {
      return [
        makeProbeResult(
          'mcp-config',
          'FAIL',
          normalizeProbeReason(error.message, 'failed to load .cursor/mcp.json'),
          'Inspect and fix .cursor/mcp.json, then re-run ./bin/init.'
        )
      ];
    }
  }

  if (fixture) {
    validateStory53FixtureAgainstActiveKeys(fixture, activeKeys);
  }

  const results = [];
  for (const serverKey of activeKeys) {
    const remediation = mcpRemediationFor(serverKey);
    if (fixture) {
      const fixtureResult = fixture.mcpResults[serverKey];
      results.push(
        makeProbeResult(
          serverKey,
          fixtureResult.status,
          normalizeProbeReason(fixtureResult.reason, 'fixture-simulated probe result'),
          remediation
        )
      );
      continue;
    }

    const serverConfig = mcpServers[serverKey];
    let probe;
    if (serverKey === 'linear') {
      probe = probeLinear(serverConfig);
    } else if (serverKey === 'github') {
      probe = probeGithub(serverConfig, env, spawnSyncImpl);
    } else if (serverKey === 'microsoft-365') {
      probe = probeMicrosoft365(serverConfig, spawnSyncImpl);
    } else if (serverKey === 'salesforce') {
      probe = probeSalesforce(serverConfig, spawnSyncImpl);
    } else if (serverKey === 'gong') {
      probe = probeGong(serverConfig, env, spawnSyncImpl);
    } else {
      probe = probeDefaultServer(serverKey, serverConfig, spawnSyncImpl);
    }

    results.push(makeProbeResult(serverKey, probe.status, probe.reason, remediation));
  }
  return results;
}

function summarizePostWizard(skillsResult, mcpResults) {
  const passCount = mcpResults.filter((result) => result.status === 'PASS').length;
  const failResults = mcpResults.filter((result) => result.status === 'FAIL');
  const failCount = failResults.length;
  const failingKeys = failResults.map((result) => result.server_key);
  const overallPass = skillsResult.status === 'PASS' && failCount === 0;

  return {
    skillsStatus: skillsResult.status,
    passCount: passCount,
    failCount: failCount,
    failingKeys: failingKeys,
    exitCode: overallPass ? 0 : 1
  };
}

function printPostWizardSummary(summary, skillsResult, mcpResults) {
  console.log('=== Story 5.3: Summary ===');
  console.log('- Skills install status: ' + summary.skillsStatus);
  console.log('- MCP checks: PASS ' + String(summary.passCount) + ', FAIL ' + String(summary.failCount));
  console.log('- Failing MCPs:');
  if (summary.failingKeys.length === 0) {
    console.log('  - none');
  } else {
    for (const key of summary.failingKeys) {
      const result = mcpResults.find((entry) => entry.server_key === key);
      console.log('  - ' + key + ': ' + result.remediation);
    }
  }
  if (skillsResult.status === 'FAIL') {
    console.log('- Skills remediation: ' + skillsResult.remediation);
  }
}

async function runPostWizardSetup(env, options = {}) {
  const fixture = options.fixture || loadStory53FixtureIfPresent(env);

  console.log('=== Story 5.3: Skills install ===');
  const skillsResult = runSkillsInstall(env, {
    fixture: fixture,
    spawnSyncImpl: options.spawnSyncImpl
  });
  console.log('[' + skillsResult.status + '] skills install - ' + skillsResult.reason);
  if (skillsResult.status === 'FAIL') {
    console.log('  Remediation: ' + skillsResult.remediation);
  }

  console.log('=== Story 5.3: Active MCP verification ===');
  const mcpResults = verifyActiveMcps(env, {
    fixture: fixture,
    spawnSyncImpl: options.spawnSyncImpl,
    mcpConfigPath: options.mcpConfigPath
  });
  for (const result of mcpResults) {
    console.log('[' + result.status + '] ' + result.server_key + ' - ' + result.reason);
    if (result.status === 'FAIL') {
      console.log('  Remediation: ' + result.remediation);
    }
  }

  const summary = summarizePostWizard(skillsResult, mcpResults);
  printPostWizardSummary(summary, skillsResult, mcpResults);
  return summary.exitCode;
}

function renderWriteSummary(writeResults) {
  const changed = writeResults.filter((result) => result.changed).map((result) => result.path + ' (' + result.action + ')');
  const skipped = writeResults.filter((result) => !result.changed).map((result) => result.path + ' (' + result.action + ')');

  console.log('Wizard completed.');
  console.log('Changed files:');
  if (changed.length === 0) {
    console.log('- none');
  } else {
    for (const item of changed) {
      console.log('- ' + item);
    }
  }
  console.log('Skipped files:');
  if (skipped.length === 0) {
    console.log('- none');
  } else {
    for (const item of skipped) {
      console.log('- ' + item);
    }
  }
}

function promptSchema(canonicalMcpKeys, shouldAskEnvOverwrite) {
  const schema = [
    {
      type: 'text',
      name: 'employeeName',
      message: 'Employee name',
      validate: (value) => (normalizeWhitespace(value) !== '' ? true : 'Employee name is required.')
    },
    {
      type: 'text',
      name: 'employeeEmail',
      message: 'Work email',
      validate: (value) => {
        const normalized = normalizeEmail(value);
        if (normalized === '') return 'Work email is required.';
        if (!BASIC_EMAIL_REGEX.test(normalized)) return 'Enter a valid work email address.';
        return true;
      }
    },
    {
      type: 'text',
      name: 'employeeRole',
      message: 'Vixxo role/title',
      validate: (value) => (normalizeWhitespace(value) !== '' ? true : 'Vixxo role/title is required.')
    },
    {
      type: 'multiselect',
      name: 'optionalMcps',
      message: 'Optional MCP interests (select zero or more)',
      instructions: false,
      choices: canonicalMcpKeys.map((key) => ({ title: key, value: key }))
    }
  ];

  if (shouldAskEnvOverwrite) {
    schema.push({
      type: 'confirm',
      name: 'overwriteEnv',
      message: '.env already exists. Overwrite with .env.example?',
      initial: false
    });
  }

  return schema;
}

async function collectWizardAnswers(promptsModule, canonicalMcpKeys, shouldAskEnvOverwrite) {
  const cancelState = { cancelled: false };
  const questions = promptSchema(canonicalMcpKeys, shouldAskEnvOverwrite);
  let answers;
  try {
    answers = await promptsModule(questions, {
      onCancel: () => {
        cancelState.cancelled = true;
        return false;
      }
    });
  } catch (error) {
    const message = String((error && error.message) || '').toLowerCase();
    if (error && (error.code === 'WIZARD_CANCELLED' || message.includes('cancel') || message.includes('abort'))) {
      cancelState.cancelled = true;
    } else {
      throw error;
    }
  }

  if (cancelState.cancelled) {
    const cancellationError = new Error('wizard-cancelled');
    cancellationError.code = 'WIZARD_CANCELLED';
    throw cancellationError;
  }

  return answers;
}

async function runWizard(promptsModule, env) {
  const canonicalMcpKeys = loadCanonicalMcpKeys();

  const envPath = assertPathInsideRepo(ENV_RELATIVE_PATH);
  let envExists = false;
  try {
    await fsp.access(envPath);
    envExists = true;
  } catch (error) {
    envExists = false;
  }

  const fixtureResponses = loadFixtureResponsesIfPresent(env);
  if (fixtureResponses) {
    validateFixtureResponses(fixtureResponses, envExists);
    promptsModule.inject(fixtureResponses);
  }

  const answers = await collectWizardAnswers(promptsModule, canonicalMcpKeys, envExists);
  const normalized = normalizeWizardAnswers(answers, canonicalMcpKeys);
  const overwriteEnv = envExists ? Boolean(answers.overwriteEnv) : true;

  const identityMarkdown = renderIdentityMarkdown(normalized);
  const workPersonaMarkdown = renderWorkPersonaMarkdown(normalized);

  await writeAtomic(assertPathInsideRepo(IDENTITY_RELATIVE_PATH), identityMarkdown);
  await writeAtomic(assertPathInsideRepo(WORK_PERSONA_RELATIVE_PATH), workPersonaMarkdown);
  const envResult = await materializeEnvFile(overwriteEnv);

  const writeResults = [
    { changed: true, action: 'written', path: IDENTITY_RELATIVE_PATH },
    { changed: true, action: 'written', path: WORK_PERSONA_RELATIVE_PATH },
    envResult
  ];
  renderWriteSummary(writeResults);
}

async function main(argv = process.argv.slice(2), env = process.env) {
  const pkg = loadPackage();
  if (argv.indexOf('--help') !== -1 || argv.indexOf('-h') !== -1) {
    printHelp(pkg);
    return 0;
  }
  if (argv.indexOf('--version') !== -1 || argv.indexOf('-v') !== -1) {
    printVersion(pkg);
    return 0;
  }

  ensureDependencies();
  const promptsModule = require('prompts');

  try {
    await runWizard(promptsModule, env);
    return await runPostWizardSetup(env);
  } catch (error) {
    if (error && error.code === 'WIZARD_CANCELLED') {
      console.error('[bin/init] setup cancelled. No files were changed; re-run ./bin/init to continue.');
      return 1;
    }
    console.error('[bin/init] setup failed: ' + (error && error.message ? error.message : 'unknown error'));
    return 1;
  }
}

if (require.main === module) {
  main().then((code) => {
    if (code !== 0) {
      process.exitCode = code;
    }
  });
}

